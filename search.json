---
layout: null
# [Status field update] Filtered search index to only include published posts.
---
[
  {% assign published_posts = "" | split: "" %}
  {% for post in site.posts %}{% if post.status == "published" %}{% assign published_posts = published_posts | push: post %}{% endif %}{% endfor %}
  {% for post in published_posts %}
  {
    "title": {{ post.title | jsonify }},
    "url": "{{ post.url | relative_url }}",
    "content": {{ post.content | strip_html | truncatewords: 200 | jsonify }},
    "date": "{{ post.date | date: '%Y-%m-%d' }}",
    "category": {{ post.category | default: "" | jsonify }},
    "tags": {{ post.tags | join: " " | jsonify }}
  }{% unless forloop.last %},{% endunless %}
  {% endfor %}
]
