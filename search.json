---
layout: null
# Local search index: blog posts + static pages + reference pages, each
# tagged with a `group` for the grouped search UI. External content
# (subdomains, github.io, repos, gists) lives in /search-external.json,
# produced by the search-crawler module. A leading-comma + `first` flag
# keeps the concatenated loops valid JSON without trailing-comma math.
---
{% assign first = true %}
[
  {% for post in site.posts %}{% if post.status == "published" %}{% unless first %},{% endunless %}{% assign first = false %}
  {
    "title": {{ post.title | jsonify }},
    "url": "{{ post.url | relative_url }}",
    "content": {{ post.content | strip_html | normalize_whitespace | truncatewords: 200 | jsonify }},
    "date": "{{ post.date | date: '%Y-%m-%d' }}",
    "category": {{ post.category | default: "" | jsonify }},
    "tags": {{ post.tags | join: " " | jsonify }},
    "group": "blog"
  }{% endif %}{% endfor %}
  {% for p in site.html_pages %}{% if p.title and p.url and p.url != "/404.html" %}{% unless first %},{% endunless %}{% assign first = false %}
  {
    "title": {{ p.title | jsonify }},
    "url": "{{ p.url | relative_url }}",
    "content": {{ p.content | strip_html | normalize_whitespace | truncatewords: 120 | jsonify }},
    "group": "{% if p.url contains '/references/' %}references{% else %}pages{% endif %}",
    "tags": ""
  }{% endif %}{% endfor %}
]
