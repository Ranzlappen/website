  },
  "main": "lib/index.js",
  "dependencies": {
    "@octokit/rest": "^22.0.1",
    "firebase-admin": "^12.0.0",
    "firebase-functions": "^5.0.0",
    "gray-matter": "^4.0.3",
    "js-yaml": "^4.1.1"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "typescript": "^5.6.3",
    "vitest": "^4.1.4"
  }
}
