{
  "rules": {
    ".read": false,
    ".write": false,
    "votes": {
      "$postSlug": {
        ".validate": "$postSlug.matches(/^[a-z0-9][a-z0-9-]{0,199}$/)",
        "$sectionId": {
          ".validate": "$sectionId.matches(/^[A-Za-z0-9_-]{1,100}$/)",
          "up": {
            ".read": true,
            ".validate": "newData.isNumber()"
          },
          "down": {
            ".read": true,
            ".validate": "newData.isNumber()"
          },
          "voters": {
            "$token": {
              ".validate": "newData.isString() && (newData.val() === 'up' || newData.val() === 'down') && $token.matches(/^[a-f0-9]{24,64}$/)"
            }
          },
          "$other": {
            ".validate": false
          }
        }
      }
    }
  }
}
