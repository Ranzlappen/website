rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Topics: anyone can read, authenticated users can create/update (vote)
    match /topics/{topicId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update: if request.auth != null;
    }

    // Change requests: anyone can read, authenticated users can create/update
    match /requests/{requestId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update: if request.auth != null;
    }

    // Topic proposals: anyone can read, authenticated users can create/update (endorse)
    match /topicRequests/{requestId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update: if request.auth != null;
    }
  }
}
