rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper functions ──
    function isSignedIn() {
      return request.auth != null;
    }
    function isAdmin() {
      return isSignedIn() && request.auth.token.role == 'admin';
    }
    function isModerator() {
      return isSignedIn() && request.auth.token.role in ['admin', 'moderator'];
    }
    function isNotBanned() {
      return isSignedIn() &&
        (!exists(/databases/$(database)/documents/users/$(request.auth.uid)) ||
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.status == 'active');
    }

    // ── Topics ──
    match /topics/{topicId} {
      allow read: if true;

      // Only admins can create topics directly (regular users go through proposals)
      allow create: if isAdmin()
        && request.resource.data.title is string
        && request.resource.data.title.size() > 0
        && request.resource.data.title.size() <= 200
        && request.resource.data.description is string
        && request.resource.data.category is string
        && request.resource.data.metrics is list
        && request.resource.data.totalVotes is int
        && request.resource.data.createdAt is int;

      // Updates allowed for authenticated non-banned users (votes update metrics + totalVotes)
      allow update: if isSignedIn() && isNotBanned()
        && request.resource.data.title == resource.data.title
        && request.resource.data.description == resource.data.description
        && request.resource.data.category == resource.data.category
        && request.resource.data.createdAt == resource.data.createdAt
        && request.resource.data.metrics is list
        && request.resource.data.totalVotes is int;

      // Only admins can delete topics
      allow delete: if isAdmin();

      // Comments subcollection – creation via Cloud Function only
      match /comments/{commentId} {
        allow read: if true;
        allow create: if false;
        // Updates (vote counts) via Cloud Functions only
        allow update: if false;
        // Moderators+ can delete comments
        allow delete: if isModerator();

        // Comment votes – managed by Cloud Functions
        match /commentVotes/{voteId} {
          allow read: if isSignedIn() && voteId == request.auth.uid;
          allow create, update, delete: if false;
        }
      }
    }

    // ── Change Requests – creation via Cloud Function only ──
    match /requests/{requestId} {
      allow read: if true;
      allow create: if false;
      // Only moderators+ can approve/reject (status transitions)
      allow update: if isModerator()
        && resource.data.status == 'pending'
        && request.resource.data.status in ['approved', 'rejected']
        && request.resource.data.topicId == resource.data.topicId
        && request.resource.data.description == resource.data.description
        && request.resource.data.type == resource.data.type;
    }

    // ── Topic Requests (Proposals) – creation and updates via Cloud Functions only ──
    match /topicRequests/{requestId} {
      allow read: if true;
      allow create: if false;
      allow update: if false;
    }

    // ── User Profiles ──
    match /users/{userId} {
      // Authenticated users can read any profile
      allow read: if isSignedIn();
      // Only Cloud Functions can create/update user profiles
      allow create, update: if false;
      allow delete: if false;
    }

    // ── Vote Records (server-side deduplication) ──
    match /votes/{voteId} {
      // Users can only read their own votes
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      // Only Cloud Functions can write vote records
      allow create, update, delete: if false;
    }

    // ── Content Reports ──
    match /reports/{reportId} {
      // Only moderators+ can read reports
      allow read: if isModerator();
      // Authenticated non-banned users can create reports (via Cloud Function preferred)
      allow create: if isSignedIn() && isNotBanned()
        && request.resource.data.reporterId == request.auth.uid
        && request.resource.data.status == 'pending'
        && request.resource.data.createdAt is int;
      // Only moderators+ can update report status
      allow update: if isModerator();
      allow delete: if false;
    }

    // ── Audit Log ──
    match /auditLog/{logId} {
      // Only admins can read audit log
      allow read: if isAdmin();
      // Only Cloud Functions can write
      allow create, update, delete: if false;
    }

    // ── Analytics ──
    match /analytics/{dateId} {
      // Only admins can read analytics
      allow read: if isAdmin();
      // Only Cloud Functions can write
      allow create, update, delete: if false;
    }
  }
}
